# Groq API Configuration
# Replace with your actual Groq API Key. DO NOT commit actual keys to version control!
GROQ_API_KEY=your_groq_api_key_here

# Model Selection Config
# Recommended default is llama-3.3-70b-versatile
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# Embeddings Config
# Recommended default is sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Vector Store Path (relative or absolute)
CHROMA_DB_DIR=vector_db

# File Upload Directory
UPLOADS_DIR=uploads

# Text Splitting Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Retrieval Settings
RETRIEVAL_K=4
